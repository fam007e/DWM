#!/bin/bash
# scripts/OpWeatherinfo - High Entropy Secured Weather Fetcher

# 1. Enforcement of Private Permissions
umask 077
CONFIG_FILE="$HOME/.config/dwm_weather.env"
LOG_FILE="$HOME/.cache/weather.log"

# 2. Secure Secret Retrieval
if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
else
    echo "[$(date)] ERROR: Configuration file $CONFIG_FILE not found." >> "$LOG_FILE"
    echo "σΑ•ë N/A"
    exit 1
fi

# Validate required variables
if [[ -z "$WEATHER_API_KEY" || -z "$WEATHER_LAT" || -z "$WEATHER_LON" ]]; then
    echo "[$(date)] ERROR: Missing configuration in $CONFIG_FILE." >> "$LOG_FILE"
    echo "σΑ•ë N/A"
    exit 1
fi

WEATHER_URL="https://api.openweathermap.org/data/2.5/weather?lat=${WEATHER_LAT}&lon=${WEATHER_LON}&appid=${WEATHER_API_KEY}"

# 3. Fetch data with timeout
WEATHER_DATA=$(curl -s --connect-timeout 5 "$WEATHER_URL")

# Check if curl succeeded and API returned valid data
if [ -z "$WEATHER_DATA" ] || echo "$WEATHER_DATA" | jq -e .cod >/dev/null 2>&1 && [ "$(echo "$WEATHER_DATA" | jq -r '.cod')" != "200" ]; then
    echo "[$(date)] API Error: $(echo "$WEATHER_DATA" | jq -c . || echo 'No response')" >> "$LOG_FILE"
    echo "σΑ•ë N/A"
    exit 1
fi

# 4. Extract and Sanitize
TEMP=$(echo "$WEATHER_DATA" | jq '.main.temp' -r)
FEELS_LIKE=$(echo "$WEATHER_DATA" | jq '.main.feels_like' -r)
WEATHER_MAIN=$(echo "$WEATHER_DATA" | jq '.weather[0].main' -r)
HUMIDITY=$(echo "$WEATHER_DATA" | jq '.main.humidity' -r)

# 5. Calculations
TEMP_C=$(printf '%.2f' "$(echo "$TEMP - 273.15" | bc)")
FEELS_LIKE_C=$(printf '%.2f' "$(echo "$FEELS_LIKE - 273.15" | bc)")

# Define icons for weather conditions
case $WEATHER_MAIN in
  Clear) ICON="σΑ•ô" ;;
  "Few Clouds") ICON="σΑ•ï" ;;
  "Scattered Clouds") ICON="σΑ•ê" ;;
  "Broken Clouds") ICON="σΑ•ê" ;;
  Clouds) ICON="σΑ•ê" ;;
  "Light Rain") ICON="σΑ•½" ;;
  Rain) ICON="σΑ••" ;;
  "Heavy Rain") ICON="σΑ••" ;;
  Drizzle) ICON="σΑ•½" ;;
  Thunderstorm) ICON="σΑ•™" ;;
  "Light Snow") ICON="σΑ•‰" ;;
  Snow) ICON="σΑ•‰" ;;
  "Heavy Snow") ICON="σΑΦΕ" ;;
  Mist|Haze|Fog|Smoke) ICON="σΑ•ë" ;;
  Dust|Sand|Squall) ICON="σΑ•ù" ;;
  Tornado) ICON="σΑΦΗ" ;;
  *) ICON="σΑ•ô" ;;
esac

# Define temperature icons
if [ "$(printf '%.0f\n' "$(echo "$TEMP_C > 27" | bc)")" -eq 1 ]; then
    TEMP_ICON="νΦΣ"
elif [ "$(printf '%.0f\n' "$(echo "$TEMP_C >= 20" | bc)")" -eq 1 ]; then
    TEMP_ICON="ο΄â"
elif [ "$(printf '%.0f\n' "$(echo "$TEMP_C >= 5" | bc)")" -eq 1 ]; then
    TEMP_ICON="νΦΪ"
else
    TEMP_ICON="ο΄΄"
fi

# 6. Final Sanitized Output
FINAL_OUTPUT=$(printf '%s %s%.0f¬ΑC(%.0f¬ΑC)πü£ß%s%%' "$ICON" "$TEMP_ICON" "$TEMP_C" "$FEELS_LIKE_C" "$HUMIDITY")
echo "$FINAL_OUTPUT" #| tr -dc '[:print:]'
