#!/bin/bash
# scripts/football-selector - Rofi-based football match selector

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MATCHES=$(python3 "$SCRIPT_DIR/footybite_scraper.py" --links)

if [[ -z "$MATCHES" ]]; then
    notify-send "Football" "No live or upcoming matches found with streaming links."
    exit 0
fi

# Format matches for Rofi (labels only)
LABELS=$(echo "$MATCHES" | awk -F'|||' '{print $1}')

# Choose match using Rofi
# Using the nord theme as it's common in this repo
THEME="$HOME/.config/rofi/themes/nord.rasi"
if [[ ! -f "$THEME" ]]; then
    # Search for any available theme if nord is missing
    THEME=$(find "$HOME/.config/rofi/themes" -name "*.rasi" | head -n 1)
fi

CHOSEN=$(echo "$LABELS" | rofi -dmenu -i -p "⚽ Match" -theme "$THEME")

if [[ -n "$CHOSEN" ]]; then
    # Get the URL for the chosen label
    URL=$(echo "$MATCHES" | grep -F "$CHOSEN" | awk -F'|||' '{print $2}' | head -n 1)
    
    if [[ -n "$URL" ]]; then
        # Check if URL is relative
        if [[ ! "$URL" =~ ^http ]]; then
             URL="https://www.footybite.do$URL"
        fi
        
        # Open in brave-origin --incognito as requested
        notify-send "Football" "Opening stream for $CHOSEN..."
        
        # Use brave-origin if it exists, else fallback to brave-browser-nightly found in config
        if command -v brave-origin >/dev/null 2>&1; then
            brave-origin --incognito "$URL" >/dev/null 2>&1 &
        else
            brave-browser-nightly --incognito "$URL" >/dev/null 2>&1 &
        fi
    else
        notify-send "Football" "Error: Could not find link for $CHOSEN"
    fi
fi
