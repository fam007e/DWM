#!/bin/bash
# scripts/football-selector — Rofi-based match selector (footybite.vc)
#
# Calls footybite_scraper.py --links to get all live/upcoming matches,
# displays them in rofi grouped by sport category, and opens the
# selected match stream in Brave (incognito).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRAPER="$SCRIPT_DIR/footybite_scraper.py"

# ── Fetch matches ────────────────────────────────────────────────────────────
RAW=$(python3 "$SCRAPER" --links 2>/dev/null) || true

if [[ -z "$RAW" ]]; then
    notify-send -u normal -i dialog-information \
        "⚽ Matches" "No live or upcoming matches found on footybite.vc"
    exit 0
fi

# ── Build rofi input ─────────────────────────────────────────────────────────
# Lines come in two forms:
#   ---🏅 Category Name---          (section header)
#   🔴 LIVE | Team1 vs Team2|||URL  (match)
#
# For rofi we show both, but category headers are non-selectable.
# We use ||| as a delimiter that rofi never sees (labels only).

LABELS=""
MATCH_COUNT=0

while IFS= read -r line; do
    if [[ "$line" == ---*--- ]]; then
        # Category header — strip the --- markers for display
        header="${line#---}"
        header="${header%---}"
        # Add a blank separator before non-first categories
        if [[ $MATCH_COUNT -gt 0 ]]; then
            LABELS+=$'\n'" "
        fi
        LABELS+=$'\n'"━━ ${header} ━━"
    else
        label="${line%%|||*}"
        LABELS+=$'\n'"$label"
        MATCH_COUNT=$((MATCH_COUNT + 1))
    fi
done <<< "$RAW"

# Trim leading newline
LABELS="${LABELS#$'\n'}"

if [[ $MATCH_COUNT -eq 0 ]]; then
    notify-send -u normal -i dialog-information \
        "⚽ Matches" "No matches parsed from footybite.vc"
    exit 0
fi

# ── Rofi theme selection ─────────────────────────────────────────────────────
# Prefer newnord, fall back to any available .rasi theme
THEME="$HOME/.config/rofi/themes/newnord.rasi"
if [[ ! -f "$THEME" ]]; then
    THEME="$HOME/.config/rofi/themes/nord.rasi"
fi
if [[ ! -f "$THEME" ]]; then
    THEME=$(find "$HOME/.config/rofi/themes" -name "*.rasi" 2>/dev/null | head -n 1)
fi

ROFI_ARGS=(-dmenu -i -p "⚽ Matches" -no-custom)
if [[ -n "${THEME:-}" && -f "${THEME:-}" ]]; then
    ROFI_ARGS+=(-theme "$THEME")
fi

# ── Show rofi and handle selection ───────────────────────────────────────────
CHOSEN=$(echo "$LABELS" | rofi "${ROFI_ARGS[@]}") || exit 0

# Ignore category headers and blank lines
if [[ -z "$CHOSEN" || "$CHOSEN" == ━━* || "$CHOSEN" == " " ]]; then
    exit 0
fi

# Find the URL for the chosen label
URL=$(echo "$RAW" | grep -F "$CHOSEN" | head -n 1 | awk -F'|||' '{print $2}')

if [[ -z "$URL" ]]; then
    notify-send -u critical -i dialog-error \
        "⚽ Matches" "Could not find stream link for:\n$CHOSEN"
    exit 1
fi

# Ensure absolute URL
if [[ ! "$URL" =~ ^https?:// ]]; then
    URL="https://footybite.vc${URL}"
fi

# ── Open in Brave incognito ──────────────────────────────────────────────────
notify-send -u low -i web-browser \
    "⚽ Opening Stream" "$CHOSEN"

if command -v brave-origin >/dev/null 2>&1; then
    brave-origin --incognito "$URL" >/dev/null 2>&1 &
elif command -v brave-browser-nightly >/dev/null 2>&1; then
    brave-browser-nightly --incognito "$URL" >/dev/null 2>&1 &
elif command -v brave-browser >/dev/null 2>&1; then
    brave-browser --incognito "$URL" >/dev/null 2>&1 &
else
    notify-send -u critical -i dialog-error \
        "⚽ Matches" "No Brave browser found (tried brave-origin, brave-browser-nightly, brave-browser)"
    exit 1
fi

disown
